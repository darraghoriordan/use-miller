{
    "name": "@use-miller/app-backend-api",
    "version": "1.0.1",
    "description": "",
    "author": "Use Miller",
    "private": true,
    "type": "module",
    "license": "UNLICENSED",
    "scripts": {
        "up": "mkdir -p ./.docker-compose/volumes/postgres ./.docker-compose/volumes/redis && chmod -R 777 ./.docker-compose || true && docker compose up -d",
        "down": "docker compose down",
        "build": "pnpm rimraf dist && pnpm nest build --tsc --path tsconfig.build.json",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start --watch",
        "start:swc": "nest start -b swc --type-check --watch",
        "dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/src/main",
        "lint": "pnpm exec eslint .",
        "lint:fix": "pnpm exec eslint . --fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "db": "typeorm-ts-node-commonjs -d node_modules/@darraghor/nest-backend-libs/dist/database-postgres/PostrgresMigrationsHelper.js",
        "db:gen": "npm run build && npm run db migration:generate",
        "db:run": "npm run db migration:run",
        "db:rev": "npm run db migration:revert",
        "stripe:wh": "stripe listen --forward-to http://localhost:34522/payments/stripe/webhook-receiver"
    },
    "dependenciesMeta": {
        "@darraghor/nest-backend-libs": {
            "injected": true
        }
    },
    "dependencies": {
        "@babel/core": "7.29.0",
        "@darraghor/nest-backend-libs": "5.7.5",
